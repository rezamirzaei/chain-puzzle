<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ChainPuzzle.Desktop.App"
             RequestedThemeVariant="Light">
  <Application.Styles>
    <FluentTheme />
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="Aptos, Segoe UI" />
    </Style>
    <Style Selector="Border.panel">
      <Setter Property="Background" Value="#DDFCF9F3" />
      <Setter Property="BorderBrush" Value="#F3FFFFFF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="26" />
      <Setter Property="Padding" Value="22" />
      <Setter Property="BoxShadow" Value="0 28 70 0 #241F2937" />
    </Style>
    <Style Selector="Border.metricCard">
      <Setter Property="Background" Value="#F8FFFEFB" />
      <Setter Property="BorderBrush" Value="#E2E8F0" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="10" />
    </Style>
    <Style Selector="Border.infoCard">
      <Setter Property="Background" Value="#F2FFFFFF" />
      <Setter Property="BorderBrush" Value="#D7E3EC" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="18" />
      <Setter Property="Padding" Value="14" />
    </Style>
    <Style Selector="Border.infoCard.accentCard">
      <Setter Property="Background" Value="#F6F1F8FF" />
    </Style>
    <Style Selector="Border.statusCard">
      <Setter Property="Background" Value="#F6F0FDF4" />
      <Setter Property="BorderBrush" Value="#D1FAE5" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="18" />
      <Setter Property="Padding" Value="14" />
    </Style>
    <Style Selector="Button.action">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
          <GradientStops>
            <GradientStop Offset="0" Color="#0F766E" />
            <GradientStop Offset="1" Color="#155E75" />
          </GradientStops>
        </LinearGradientBrush>
      </Setter>
      <Setter Property="BorderBrush" Value="#0F525D" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="13,9" />
      <Setter Property="Margin" Value="0,0,0,8" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="CornerRadius" Value="14" />
    </Style>
    <Style Selector="Button.action.secondary">
      <Setter Property="Foreground" Value="#0F172A" />
      <Setter Property="Background" Value="#F8FAFC" />
      <Setter Property="BorderBrush" Value="#D6DEE8" />
    </Style>
    <Style Selector="Button.action:pointerover">
      <Setter Property="Opacity" Value="0.96" />
    </Style>
    <Style Selector="Button.action:pressed">
      <Setter Property="Opacity" Value="0.9" />
    </Style>
    <Style Selector="Button.action:disabled">
      <Setter Property="Opacity" Value="0.5" />
    </Style>
    <Style Selector="Button.chapterCard">
      <Setter Property="Foreground" Value="#0F172A" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Opacity" Value="1" />
      <Setter Property="CornerRadius" Value="20" />
    </Style>
    <Style Selector="Button.chapterCard:pointerover">
      <Setter Property="Opacity" Value="0.98" />
    </Style>
    <Style Selector="Button.chapterCard:pressed">
      <Setter Property="Opacity" Value="0.93" />
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="Background" Value="#F8FAFC" />
      <Setter Property="BorderBrush" Value="#CBD5E1" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="MinHeight" Value="40" />
    </Style>
  </Application.Styles>
</Application>
