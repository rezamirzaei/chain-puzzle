<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:ChainPuzzle.Desktop.Controls"
        x:Class="ChainPuzzle.Desktop.MainWindow"
        Width="1420"
        Height="920"
        MinWidth="980"
        MinHeight="680"
        Title="Christmas Tree Chain Puzzle"
        KeyDown="Window_OnKeyDown">
  <Grid>
    <controls:ChainBoardControl x:Name="Board"
                                PointerPressed="Board_OnPointerPressed"
                                PointerMoved="Board_OnPointerMoved"
                                PointerReleased="Board_OnPointerReleased" />

    <Border x:Name="HomeOverlay"
            IsVisible="False"
            Background="#A60F172A">
      <Grid>
        <Border Width="640"
                Padding="26"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Classes="panel">
          <StackPanel>
            <TextBlock Text="Chain Puzzle"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="#0F766E" />
            <TextBlock x:Name="HomeTitleText"
                       Margin="0,10,0,0"
                       FontSize="42"
                       FontWeight="SemiBold"
                       Foreground="#0F172A" />
            <TextBlock x:Name="HomeSummaryText"
                       Margin="0,10,0,16"
                       FontSize="16"
                       Foreground="#334155"
                       TextWrapping="Wrap" />

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="10"
                  Margin="0,0,0,16">
              <Border Grid.Column="0"
                      CornerRadius="12"
                      Background="#F8FAFC"
                      BorderBrush="#D1D5DB"
                      BorderThickness="1"
                      Padding="12">
                <StackPanel>
                  <TextBlock Text="Run Status"
                             FontSize="11"
                             Foreground="#64748B" />
                  <TextBlock x:Name="HomeProgressText"
                             FontSize="16"
                             FontWeight="Bold"
                             Foreground="#0F172A" />
                </StackPanel>
              </Border>
              <Border Grid.Column="1"
                      CornerRadius="12"
                      Background="#F8FAFC"
                      BorderBrush="#D1D5DB"
                      BorderThickness="1"
                      Padding="12">
                <StackPanel>
                  <TextBlock Text="Best Progress"
                             FontSize="11"
                             Foreground="#64748B" />
                  <TextBlock x:Name="HomeBestText"
                             FontSize="16"
                             FontWeight="Bold"
                             Foreground="#0F172A" />
                </StackPanel>
              </Border>
            </Grid>

            <TextBlock Text="Rotate the wooden chain until it matches the filled target silhouette. Shorter solves beat par."
                       Margin="0,0,0,18"
                       FontSize="15"
                       Foreground="#475569"
                       TextWrapping="Wrap" />

            <Grid ColumnDefinitions="*,*,*"
                  ColumnSpacing="10">
              <Button x:Name="HomePrimaryButton"
                      Grid.Column="0"
                      Classes="action"
                      Content="Start Game"
                      Click="HomePrimaryButton_OnClick" />
              <Button x:Name="HomeSecondaryButton"
                      Grid.Column="1"
                      Classes="action secondary"
                      Content="New Run"
                      Click="HomeSecondaryButton_OnClick" />
              <Button x:Name="HomeCloseButton"
                      Grid.Column="2"
                      Classes="action secondary"
                      Content="Close Menu"
                      Click="HomeCloseButton_OnClick" />
            </Grid>
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <Border x:Name="SolvedCard"
            Width="380"
            Padding="18"
            Margin="0,0,0,24"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            IsVisible="False"
            Classes="panel">
      <StackPanel>
        <TextBlock x:Name="SolvedTitleText"
                   FontSize="26"
                   FontWeight="SemiBold"
                   Foreground="#0F172A" />
        <TextBlock x:Name="SolvedSummaryText"
                   Margin="0,8,0,14"
                   FontSize="15"
                   Foreground="#334155"
                   TextWrapping="Wrap" />
        <Grid ColumnDefinitions="*,*"
              ColumnSpacing="10">
          <Button x:Name="SolvedResetButton"
                  Grid.Column="0"
                  Classes="action secondary"
                  Content="Replay Chapter"
                  Click="SolvedResetButton_OnClick" />
          <Button x:Name="SolvedNextButton"
                  Grid.Column="1"
                  Classes="action"
                  Content="Next Chapter"
                  Click="SolvedNextButton_OnClick" />
        </Grid>
      </StackPanel>
    </Border>

    <Grid Margin="16"
          ColumnDefinitions="420,*,320">
      <Border Grid.Column="0"
              VerticalAlignment="Top"
              Classes="panel">
        <StackPanel>
          <TextBlock Text="Chain Puzzle"
                     FontSize="13"
                     FontWeight="Bold"
                     Foreground="#1D4ED8" />
          <TextBlock x:Name="TitleText"
                     Margin="0,8,0,0"
                     FontSize="30"
                     FontWeight="SemiBold"
                     Foreground="#0F172A" />
          <TextBlock x:Name="SubtitleText"
                     Margin="0,0,0,10"
                     FontSize="19"
                     Foreground="#475569" />
          <TextBlock x:Name="DescriptionText"
                     Margin="0,0,0,14"
                     TextWrapping="Wrap"
                     FontSize="15"
                     Foreground="#334155" />

          <TextBlock Text="Jump To Chapter"
                     FontSize="11"
                     FontWeight="Bold"
                     Foreground="#64748B" />
          <ComboBox x:Name="ChapterPicker"
                    Margin="0,6,0,14"
                    SelectionChanged="ChapterPicker_OnSelectionChanged" />

          <Grid ColumnDefinitions="*,*"
                RowDefinitions="Auto,Auto"
                ColumnSpacing="8"
                RowSpacing="8"
                Margin="0,0,0,12">
            <Border Grid.Column="0"
                    Grid.Row="0"
                    CornerRadius="10"
                    Background="#F8FAFC"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    Padding="8">
              <StackPanel>
                <TextBlock Text="Progress"
                           FontSize="11"
                           Foreground="#64748B" />
                <TextBlock x:Name="ProgressText"
                           FontSize="14"
                           FontWeight="Bold" />
              </StackPanel>
            </Border>
            <Border Grid.Column="1"
                    Grid.Row="0"
                    CornerRadius="10"
                    Background="#F8FAFC"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    Padding="8">
              <StackPanel>
                <TextBlock Text="Chapters Cleared"
                           FontSize="11"
                           Foreground="#64748B" />
                <TextBlock x:Name="CompletedText"
                           FontSize="14"
                           FontWeight="Bold" />
              </StackPanel>
            </Border>
            <Border Grid.Column="0"
                    Grid.Row="1"
                    CornerRadius="10"
                    Background="#F8FAFC"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    Padding="8">
              <StackPanel>
                <TextBlock Text="Moves"
                           FontSize="11"
                           Foreground="#64748B" />
                <TextBlock x:Name="MovesText"
                           FontSize="14"
                           FontWeight="Bold" />
              </StackPanel>
            </Border>
            <Border Grid.Column="1"
                    Grid.Row="1"
                    CornerRadius="10"
                    Background="#F8FAFC"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    Padding="8">
              <StackPanel>
                <TextBlock Text="Best / Par"
                           FontSize="11"
                           Foreground="#64748B" />
                <TextBlock x:Name="BestText"
                           FontSize="14"
                           FontWeight="Bold" />
              </StackPanel>
            </Border>
          </Grid>

          <Border x:Name="ValidationBadge"
                  Background="#1E1D4ED8"
                  BorderBrush="#421D4ED8"
                  BorderThickness="1"
                  CornerRadius="20"
                  Padding="10,5"
                  HorizontalAlignment="Left">
            <TextBlock x:Name="ValidationText"
                       FontWeight="Bold"
                       Foreground="#1D4ED8" />
          </Border>

          <TextBlock x:Name="StatusText"
                     Margin="0,12,0,0"
                     FontSize="15"
                     FontWeight="SemiBold"
                     Foreground="#0F172A"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <Border Grid.Column="2"
              VerticalAlignment="Top"
              Classes="panel">
        <StackPanel>
          <Button x:Name="PreviousButton"
                  Classes="action secondary"
                  Content="Previous"
                  Click="PreviousButton_OnClick" />
          <Button x:Name="NextButton"
                  Classes="action"
                  Content="Next"
                  Click="NextButton_OnClick" />
          <Button x:Name="UndoButton"
                  Classes="action secondary"
                  Content="Undo"
                  Click="UndoButton_OnClick" />
          <Button x:Name="RedoButton"
                  Classes="action secondary"
                  Content="Redo"
                  Click="RedoButton_OnClick" />
          <Button x:Name="MenuButton"
                  Classes="action secondary"
                  Content="Menu"
                  Click="MenuButton_OnClick" />
          <Button x:Name="ResetButton"
                  Classes="action secondary"
                  Content="Reset"
                  Click="ResetButton_OnClick" />
          <Button x:Name="HintButton"
                  Classes="action"
                  Content="Nudge"
                  Click="HintButton_OnClick" />
          <Button x:Name="RotateLeftButton"
                  Classes="action"
                  Content="Rotate Left"
                  Click="RotateLeftButton_OnClick" />
          <Button x:Name="RotateRightButton"
                  Classes="action"
                  Content="Rotate Right"
                  Click="RotateRightButton_OnClick" />
          <TextBlock Margin="0,6,0,0"
                     TextWrapping="Wrap"
                     Foreground="#475569"
                     Text="Click near a joint, then drag or use Rotate Left/Right.&#10;Keyboard: Up/Down chooses a joint. A/D rotates. Ctrl+Z undoes, Ctrl+Y redoes. Nudge reveals a joint and direction, but does not move it for you." />
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</Window>
